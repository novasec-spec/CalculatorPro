{
  "expo": {
    "name": "Calculator",
    "slug": "calculator",
    "scheme": "novasec",
    "version": "1.0.0",
    "sdkVersion": "54.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.novasec.calculator"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.novasec.calculator",
      "permissions": [
        "android.permission.INTERNET",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-audio",
      [
        "react-native-android-widget",
        {
          "widgets": [
            {
              "name": "RatesWidget",
              "label": "NovaSec1 Rates",
              "description": "Live USD→KES, BTC & ETH prices",
              "previewImage": "./assets/widget-preview.png",
              "minWidth": "250dp",
              "minHeight": "110dp",
              "maxResizeWidth": "250dp",
              "maxResizeHeight": "220dp",
              "targetCellWidth": 4,
              "targetCellHeight": 2,
              "resizeMode": "horizontal|vertical",
              "updatePeriodMillis": 1800000,
              "widgetFeatures": 5
            }
          ]
        }
      ],
      "expo-font",
      "expo-asset"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "d41896f6-7212-4b08-ba8b-19ab29dba416"
      }
    }
  }
}
